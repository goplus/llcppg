package enum

import _ "unsafe"

const (
	Enum1 int32 = 0
	Enum2 int32 = 1
)
const COLORDEFAULT int32 = -1

type Spectrum int32

const (
	Red    Spectrum = 0
	Orange Spectrum = 1
	Yello  Spectrum = 2
	Green  Spectrum = 3
	Blue   Spectrum = 4
	Violet Spectrum = 5
)

type Kids int32

const (
	Nippy  Kids = 0
	Slats  Kids = 1
	Skippy Kids = 2
	Nina   Kids = 3
	Liz    Kids = 4
)

type Levels int32

const (
	Low    Levels = 100
	Medium Levels = 500
	High   Levels = 2000
)

type Feline int32

const (
	Cat   Feline = 0
	Lynx  Feline = 10
	Puma  Feline = 11
	Tiger Feline = 12
)

type Algorithm int32

const (
	UNKNOWN Algorithm = 0
	NULL    Algorithm = 1
)

type AlgorithmT Algorithm
type AlgorithmT2 int32

const (
	UNKNOWN2 AlgorithmT2 = 0
	NULL2    AlgorithmT2 = 1
)

type CodeT int32

const (
	NOERROR        CodeT = 0
	GENERAL        CodeT = 1
	UNKNOWNPACKET  CodeT = 2
	UNKNOWNVERSION CodeT = 3
	PUBKEYALGO     CodeT = 4
	DIGESTALGO     CodeT = 5
	BADPUBKEY      CodeT = 6
	BADSECKEY      CodeT = 7
	BADSIGNATURE   CodeT = 8
	NOPUBKEY       CodeT = 9
	CHECKSUM       CodeT = 10
	BADPASSPHRASE  CodeT = 11
	CIPHERALGO     CodeT = 12
	KEYRINGOPEN    CodeT = 13
	INVPACKET      CodeT = 14
	INVARMOR       CodeT = 15
	NOUSERID       CodeT = 16
	NOSECKEY       CodeT = 17
	WRONGSECKEY    CodeT = 18
	BADKEY         CodeT = 19
)

